# Required for Hub upload
HF_TOKEN=hf_xxx
HF_REPO_ID=your-username/odse-grpo-model
PUSH_TO_HUB=1

# ODSE environment space URL
ENV_BASE_URL=https://simeetnayan-odse.hf.space

# Base model and training knobs
MODEL_NAME=Qwen/Qwen3.5-4B
FALLBACK_MODEL_NAME=Qwen/Qwen2.5-3B-Instruct
VLLM_FALLBACK_MODEL_NAME=Qwen/Qwen3-4B
OOM_FALLBACK_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
NUM_EPOCHS=1
DATASET_SIZE=24
NUM_GENERATIONS=2
LEARNING_RATE=5e-6
WEIGHT_DECAY=0.0
GRADIENT_ACCUMULATION_STEPS=16
PER_DEVICE_BATCH_SIZE=1
WARMUP_STEPS=20
LOGGING_STEPS=1
MAX_COMPLETION_LENGTH=256

# Keep colocate unless you run an external vLLM server
USE_VLLM=1
VLLM_MODE=colocate
# VLLM_SERVER_URL=http://localhost:8000
